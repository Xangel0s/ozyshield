# OzyShield Server Configuration
# Copy this file to .env and adjust values

# Server port
OZY_PORT=8080

# Admin credentials (used for default admin user)
OZY_ADMIN_EMAIL=admin@ozyshield.local
OZY_ADMIN_PASSWORD=admin123

# API authentication token (Bearer token for dashboard)
OZY_AUTH_TOKEN=demo-token-123

# Allow public user registration (true/false)
OZY_ENABLE_REGISTRATION=true

# Default role for new users (admin/member)
OZY_DEFAULT_ROLE=member

# JWT secret for session tokens (change in production!)
OZY_JWT_SECRET=ozyshield-dev-secret-change-in-production
